# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=p5_admin
POSTGRES_PASSWORD=p5_secret
POSTGRES_DB=p5_billing
DATABASE_URL=postgres://p5_admin:p5_secret@localhost:5432/p5_billing

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO ───────────────────────────────────────────────
MINIO_ROOT_USER=p5_minio_admin
MINIO_ROOT_PASSWORD=p5_minio_secret
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=p5_minio_admin
MINIO_SECRET_KEY=p5_minio_secret
